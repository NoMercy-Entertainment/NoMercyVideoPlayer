{
	"name": "@nomercy-entertainment/nomercy-video-player",
	"type": "module",
	"version": "1.2.6",
	"description": "Headless, event-driven HTML5 video player with HLS streaming, subtitle rendering (VTT/ASS/SSA), and a plugin system. No UI — you build your own.",
	"author": {
		"name": "NoMercy Entertainment",
		"email": "info@nomercy.tv",
		"url": "https://nomercy.tv"
	},
	"contributors": [
		"Stoney Eagle <stoney@nomercy.tv>"
	],
	"license": "Apache-2.0",
	"homepage": "https://github.com/NoMercy-Entertainment/nomercy-video-player",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NoMercy-Entertainment/nomercy-video-player.git"
	},
	"keywords": [
		"video",
		"player",
		"video-player",
		"headless",
		"hls",
		"hls-player",
		"html5",
		"typescript",
		"plugin",
		"streaming",
		"subtitles",
		"ass",
		"ssa",
		"vtt",
		"adaptive",
		"playlist",
		"media",
		"no-ui",
		"event-driven"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/nomercy-video-player.js"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/nomercy-video-player.cjs"
			}
		},
		"./src/types": "./src/types.ts",
		"./src/types.ts": "./src/types.ts",
		"./src": "./src/index.ts",
		"./src/index": "./src/index.ts",
		"./src/player/utils": "./src/player/utils.ts",
		"./src/plugin": "./src/plugins/plugin.ts",
		"./src/plugins/octopusPlugin": "./src/plugins/octopusPlugin.ts",
		"./src/plugins/keyHandlerPlugin": "./src/plugins/keyHandlerPlugin.ts",
		"./src/plugins/*": "./src/plugins/*",
		"./dist/*": "./dist/*"
	},
	"main": "./dist/nomercy-video-player.cjs",
	"module": "./dist/nomercy-video-player.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"public",
		"src"
	],
	"scripts": {
		"build": "vite build && vite build --config vite.config.iife.ts",
		"dev": "vite --port 5502 --host",
		"lint": "eslint --fix .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui --watch",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "npx playwright test",
		"test:e2e:report": "npx playwright show-report reports/playwright",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@nomercy-entertainment/media-session": "^1.1.2",
		"hls.js": "1.6.15",
		"webvtt-parser": "2.2.0"
	},
	"devDependencies": {
		"@antfu/eslint-config": "5.3.0",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/line-clamp": "0.4.4",
		"@types/webvtt-parser": "2.2.0",
		"@vitest/coverage-v8": "^4.1.2",
		"@vitest/ui": "^4.1.2",
		"autoprefixer": "10.4.27",
		"copyfiles": "2.4.1",
		"css-loader": "6.8.1",
		"eslint": "^9.0.0",
		"eslint-plugin-format": "1.0.1",
		"happy-dom": "^20.8.9",
		"playwright": "^1.59.1",
		"postcss": "8.5.8",
		"postcss-loader": "7.3.3",
		"postcss-nested": "7.0.2",
		"postcss-preset-env": "9.2.0",
		"prettier": "3.3.3",
		"prettier-eslint": "^16.4.2",
		"sass": "1.85.0",
		"sass-loader": "13.3.2",
		"shx": "0.4.0",
		"tailwindcss": "3.2.7",
		"tailwindcss-children": "2.1.0",
		"ts-loader": "9.4.4",
		"ts-node": "10.9.2",
		"typescript": "5.8.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "4.5.4",
		"vitest": "^4.1.2",
		"webpack": "^5.105.4",
		"webpack-cli": "5.1.4",
		"webpack-dev-server": "5.2.3"
	},
	"overrides": {
		"minimatch": "10.2.4"
	},
	"publishConfig": {
		"access": "public"
	}
}
